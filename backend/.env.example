# FastAPI 配置
APP_NAME=Loom API
APP_VERSION=0.1.0
DEBUG=True

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 数据库配置
DATABASE_URL=sqlite:///./data/loom.db
# DATABASE_URL=postgresql://loom:loom_password@postgres:5432/loom_db

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# Celery 配置
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# OpenAI / Ollama 配置
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
# 对于本地 Ollama: OPENAI_BASE_URL=http://localhost:11434/v1

# 认证配置
JWT_SECRET_KEY=please-change-this-to-a-random-32-byte-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin123456
DEFAULT_ADMIN_NAME=系统管理员

# CORS 配置
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
